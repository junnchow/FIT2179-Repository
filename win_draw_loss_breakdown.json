{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {"text": "Malaysia's Win/Draw/Loss Breakdown vs Opponents", "fontSize": 16},
  "data": {"url": "asean_results.csv", "format": {"type": "csv"}},
  "transform": [
    {"filter": "datum.home_team == 'Malaysia' || datum.away_team == 'Malaysia'"},
    {"calculate": "datum.home_team == 'Malaysia' ? datum.away_team : datum.home_team", "as": "opponent"},
    {"calculate": "(datum.home_team == 'Malaysia' && datum.home_score > datum.away_score) || (datum.away_team == 'Malaysia' && datum.away_score > datum.home_score) ? 'Win' : (datum.home_score == datum.away_score ? 'Draw' : 'Loss')", "as": "result"},
    {"aggregate": [{"op": "count", "as": "count"}], "groupby": ["opponent", "result"]},
    {"joinaggregate": [{"op": "sum", "field": "count", "as": "total_count"}], "groupby": ["opponent"]},
    {"calculate": "datum.count / datum.total_count * 100", "as": "percentage"},
    {"filter": "datum.total_count >= 5"}
  ],
  "width": "container",
  "height": 400,
  "mark": {"type": "bar", "stroke": "white", "strokeWidth": 1, "cornerRadiusEnd": 3},
  "encoding": {
    "x": {"field": "opponent", "type": "nominal", "title": "Opponent", "sort": "-y", "axis": {"labelAngle": -45, "titleFontSize": 14, "labelFontSize": 12}},
    "y": {"field": "percentage", "type": "quantitative", "title": "Percentage (%)", "stack": "normalize", "axis": {"titleFontSize": 14, "labelFontSize": 12, "format": ".0f", "grid": true}},
    "color": {
      "field": "result",
      "type": "nominal",
      "scale": {
        "domain": ["Win", "Draw", "Loss"],
        "range": ["#4c72b0", "#f39c12", "#7f8c8d"]
      },
      "legend": {"title": "Outcome", "titleFontSize": 14, "labelFontSize": 12, "orient": "top"}
    },
    "tooltip": [
      {"field": "opponent", "title": "Opponent"},
      {"field": "result", "title": "Result"},
      {"field": "percentage", "type": "quantitative", "format": ".1f", "title": "Percentage (%)"},
      {"field": "count", "title": "Matches"}
    ]
  },
  "config": {"view": {"stroke": null}}
}