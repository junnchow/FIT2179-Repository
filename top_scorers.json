{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {"text": "Malaysia's Prolific Scorers (International Goals)", "fontSize": 16},
  "data": {"url": "malaysia_scorers.csv", "format": {"type": "csv"}},
  "transform": [
    {"filter": "datum.scorer != null && datum.own_goal == 'False'"},
    {"aggregate": [{"op": "count", "as": "goals"}], "groupby": ["scorer"]},
    {"filter": "datum.goals >= 2"},
    {"window": [{"op": "rank", "as": "rank"}], "sort": [{"field": "goals", "order": "descending"}]},
    {"filter": "datum.rank <= 12"},
    {"joinaggregate": [{"op": "mean", "field": "goals", "as": "avg_goals"}]}
  ],
  "layer": [
    {
      "mark": {"type": "bar", "cornerRadiusEnd": 3},
      "encoding": {
        "x": {"field": "goals", "type": "quantitative", "title": "Goals", "axis": {"titleFontSize": 14, "labelFontSize": 12}},
        "y": {"field": "scorer", "type": "nominal", "title": "Player", "sort": "-x", "axis": {"titleFontSize": 14, "labelFontSize": 12}},
        "color": {
          "condition": {"test": "datum.goals > datum.avg_goals", "value": "#2c7fb8"},
          "value": "#cccccc"
        },
        "tooltip": [{"field": "scorer"}, {"field": "goals"}]
      }
    },
    {
      "mark": {"type": "rule", "color": "black", "strokeWidth": 1.5, "strokeDash": [4, 4]},
      "encoding": {
        "x": {"aggregate": "mean", "field": "goals", "type": "quantitative"},
        "tooltip": [{"aggregate": "mean", "field": "goals", "title": "Average goals", "format": ".1f"}]
      }
    }
  ],
  "width": "container",
  "height": 450,
  "config": {"view": {"stroke": null}}
}